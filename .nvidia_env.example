# NVIDIA API Key (Required)
NVIDIA_API_KEY=your_api_key_here

# Model to use (Optional, default: nvidia/llama-3.1-nemotron-70b-instruct)
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# API Base URL (Optional, usually no need to change)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Debug mode: 1 to enable, 0 to disable (Optional)
NVIDIA_DEBUG=0
